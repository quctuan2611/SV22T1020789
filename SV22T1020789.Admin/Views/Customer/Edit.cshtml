@model Customer

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu dữ liệu
    </button>

    <a href="~/Customer" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        @Html.ValidationMessage("Error", new {@class="text-danger"})
        <div class="card card-primary card-outline">

            <!-- Header -->
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-people me-2"></i>
                    Thông tin khách hàng
                </h5>
            </div>

            <!-- Body -->
            <div class="card-body">
                <form id="formEdit" method="post" action="~/Customer/SaveData">

                    <!-- Hidden ID -->
                    <input type="hidden" asp-for="CustomerID" />

                    <!-- Row 1 -->
                    <div class="row align-items-end">
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Tên khách hàng</label>
                            <input asp-for="CustomerName"
                                   type="text"
                                   class="form-control"
                                   placeholder="" autofocus />
                            <span asp-validation-for="CustomerName" class="text-danger"></span>
                        </div>

                        <div class="col-md-5 mb-3">
                            <label class="form-label">Tên giao dịch</label>
                            <input asp-for="ContactName"
                                   type="text"
                                   class="form-control"
                                   placeholder="Nhập tên giao dịch" />
                        </div>

                        <div class="col-md-2 mb-3">
                            <label class="form-label d-block">Trạng thái</label>
                            <div class="form-check form-switch mt-2">
                                <input asp-for="IsLocked"
                                       class="form-check-input"
                                       type="checkbox"
                                       id="IsLocked" />
                                <label class="form-check-label" for="IsLocked">
                                    Đã bị khoá
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Row 2 -->
                    <div class="row">
                        <div class="col-md-5 mb-3">
                            <label class="form-label">Điện thoại</label>
                            <input asp-for="Phone"
                                   type="tel"
                                   class="form-control"
                                   placeholder="Nhập số điện thoại" />
                        </div>

                        <div class="col-md-7 mb-3">
                            <label class="form-label">Email</label>
                            <input asp-for="Email"
                                   type="email"
                                   class="form-control"
                                   placeholder="Nhập email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Address -->
                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <textarea asp-for="Address"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Nhập địa chỉ"></textarea>
                    </div>

                    <!-- Province -->
                    <div class="mb-3">
                        <label class="form-label">Tỉnh / Thành</label>
                        <select asp-for="Province"
                                asp-items="await SelectListHelper.Provinces()"
                                class="form-select">
                        </select>
                        <span asp-validation-for="Province" class="text-danger"></span>
                    </div>

                </form>
            </div>

        </div>
    </div>
</div>