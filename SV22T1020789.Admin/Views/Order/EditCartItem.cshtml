@model OrderDetailViewInfo
@{
    Layout = null;
}
<div class="modal-header">
    <strong class="modal-title">
        Cập nhật mặt hàng trong giỏ hàng
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form id="formEditCartItem"
      action="~/Order/UpdateCartItem"
      method="post"
      onsubmit="UpdateCartItem(event, this)">

    <div class="modal-body">
        <input type="hidden" asp-for="ProductID" />
        <div class="row">
            <div class="col-md-8">
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Mặt hàng
                    </label>
                    <div class="col-sm-8">
                        <input type="text"
                               class="form-control-plaintext fw-bold"
                               value="@Model.ProductName"
                               readonly>
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Số lượng
                    </label>
                    <div class="col-sm-5">
                        <input type="number" asp-for="Quantity"
                               class="form-control text-end"
                               min="1" />
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-4 col-form-label fw-semibold">
                        Đơn giá
                    </label>
                    <div class="col-sm-5">
                        <input type="text" asp-for="SalePrice"
                               class="form-control text-end money-input" />
                    </div>
                </div>
            </div>
            <div class="col-md-4 text-end">
                <img src="/images/products/@Model.Photo"
                     alt="Tên mặt hàng"
                     class="img-thumbnail"
                     style="max-height:180px">
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            Cập nhật
        </button>
        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>