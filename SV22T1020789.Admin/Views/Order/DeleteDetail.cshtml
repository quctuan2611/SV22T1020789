@model OrderDetailViewInfo

<form action="~/Order/DeleteDetail/@Model.OrderID?productId=@Model.ProductID" method="post">
    <div class="modal-header bg-danger">
        <h5 class="modal-title text-white">Xóa mặt hàng khỏi đơn</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>

    <div class="modal-body text-center">
        <div class="mb-3 text-danger">
            <i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i>
        </div>
        <h5>Bạn có chắc chắn muốn xóa mặt hàng này khỏi đơn hàng?</h5>
        <p class="text-muted mb-0"><strong>@Model.ProductName</strong></p>
        <p class="text-muted">Số lượng: @Model.Quantity | Giá: @Model.SalePrice.ToString("N0")</p>
    </div>

    <div class="modal-footer justify-content-center">
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash"></i> Xác nhận xóa
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
    </div>
</form>