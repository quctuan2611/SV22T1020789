@model PaginationSearchInput
@{
    ViewBag.Title = "Quản lý Loại hàng";
}

@section PageToolBar {
    <a href="~/Category/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch"
              method="get"
              action="~/Category/Search"
              data-target="searchResult"
              onsubmit="paginationSearch(event, this, 1)">

            <div class="input-group">
                <input type="hidden" asp-for="PageSize" />
                <input type="text"
                       class="form-control"
                       asp-for="SearchValue"
                       placeholder="Nhập tên loại hàng cần tìm..." autofocus />

                <button class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<div id="searchResult"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Tự động gọi hàm tìm kiếm khi vừa load trang xong
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
        });
    </script>
}