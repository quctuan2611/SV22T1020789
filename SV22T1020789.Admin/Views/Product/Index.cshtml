@model ProductSearchInput
@{
    ViewBag.Title = "Quản lý Mặt hàng";
}

@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch"
              method="get"
              action="~/Product/Search"
              data-target="searchResult"
              onsubmit="paginationSearch(event, this, 1)">

            <input type="hidden" asp-for="PageSize" />

            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select class="form-select" asp-for="CategoryID">
                        <option value="0">-- Tất cả --</option>
                        @foreach (var item in ViewBag.Categories)
                        {
                            <option value="@item.CategoryID">@item.CategoryName</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Nhà cung cấp</label>
                    <select class="form-select" asp-for="SupplierID">
                        <option value="0">-- Tất cả --</option>
                        @foreach (var item in ViewBag.Suppliers)
                        {
                            <option value="@item.SupplierID">@item.SupplierName</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        <input type="text"
                               class="form-control number-separator"
                               name="MinPrice"
                               value="@(Model.MinPrice == 0 ? "" : Model.MinPrice.ToString("0.##"))"
                               placeholder="Từ" />
                        <span class="input-group-text">-</span>
                        <input type="text"
                               class="form-control number-separator"
                               name="MaxPrice"
                               value="@(Model.MaxPrice == 0 ? "" : Model.MaxPrice.ToString("0.##"))"
                               placeholder="Đến" />
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input type="text"
                               class="form-control"
                               asp-for="SearchValue"
                               placeholder="Tên mặt hàng..." autofocus />
                        <button class="btn btn-info d-flex align-items-center">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="searchResult"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Tự động tìm kiếm ngay khi load trang
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
        });
    </script>
}