@{
    ViewBag.Title = "Bổ sung thuộc tính";
    
    var productId = ViewBag.ProductID;
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">

                <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-primary">
                        <i class="fas fa-plus-circle me-2"></i> Bổ sung thuộc tính
                    </h5>
                    
                </div>

                <div class="card-body p-4">

                    <form action="/Product/CreateAttribute/@productId" method="post">

                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">Tên thuộc tính <span class="text-danger">*</span>:</label>
                            <input type="text" class="form-control" name="Name" placeholder="Ví dụ: Màu sắc, Size, Chất liệu..." required autofocus>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">Giá trị <span class="text-danger">*</span>:</label>
                            <input type="text" class="form-control" name="Value" placeholder="Ví dụ: Xanh, XL, Cotton 100%..." required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold small text-muted">Thứ tự hiển thị:</label>
                            <input type="number" class="form-control w-25" name="DisplayOrder" value="1">
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a href="/Product/Edit/@productId" class="btn btn-light border">
                                Quay lại
                            </a>
                            <button type="submit" class="btn btn-primary px-4 fw-bold">
                                <i class="fas fa-save me-1"></i> Lưu dữ liệu
                            </button>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>