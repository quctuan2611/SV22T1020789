@model Employee
@{
    ViewBag.Title = "Xóa nhân viên";
}

@section PageToolBar {
    
    @if (!Model.IsWorking && ViewBag.AllowDelete)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formDelete" method="post" action="~/Employee/Delete/@Model.EmployeeID">

                    
                    @if (Model.IsWorking)
                    {
                        <div class="alert alert-info d-flex align-items-center">
                            <i class="bi bi-info-circle me-2"></i>
                            Không thể xóa! Nhân viên này đang trong trạng thái "Đang làm việc".
                        </div>
                    }
                    else if (!ViewBag.AllowDelete)
                    {
                        <div class="alert alert-warning d-flex align-items-center">
                            <i class="bi bi-shield-exclamation me-2"></i>
                            Không thể xóa! Nhân viên này đã nghỉ việc nhưng đã có dữ liệu lịch sử (đơn hàng, v.v.).
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-danger d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            Bạn có chắc chắn muốn xóa nhân viên này không? Thao tác này không thể phục hồi!
                        </div>
                    }

                    <div class="row mt-4">
                        <div class="col-md-3 text-center mb-3">
                            <img src="~/images/employees/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                 class="img-thumbnail"
                                 style="max-width: 150px; height: auto;"
                                 alt="Ảnh nhân viên" />
                        </div>

                        <div class="col-md-9">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Họ và tên</dt>
                                <dd class="col-sm-8"><strong>@Model.FullName</strong></dd>

                                <dt class="col-sm-4">Ngày sinh</dt>
                                <dd class="col-sm-8">@(Model.BirthDate?.ToString("dd/MM/yyyy"))</dd>

                                <dt class="col-sm-4">Điện thoại</dt>
                                <dd class="col-sm-8">@Model.Phone</dd>

                                <dt class="col-sm-4">Email</dt>
                                <dd class="col-sm-8">@Model.Email</dd>

                                <dt class="col-sm-4">Địa chỉ</dt>
                                <dd class="col-sm-8">@Model.Address</dd>

                                <dt class="col-sm-4">Trạng thái</dt>
                                <dd class="col-sm-8">
                                    @if (Model.IsWorking)
                                    {
                                        <span class="badge bg-success">Đang làm việc</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Đã nghỉ việc</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>