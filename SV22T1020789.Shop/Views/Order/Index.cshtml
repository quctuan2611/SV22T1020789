@model IEnumerable<SV22T1020789.Models.Sales.OrderViewInfo>

@{
    ViewData["Title"] = "Lịch sử mua hàng";
    var orderTotals = ViewBag.OrderTotals as Dictionary<int, decimal> ?? new Dictionary<int, decimal>();
}

<div class="container mt-4 mb-5">
    <h3 class="fw-bold text-primary mb-4"><i class="bi bi-clock-history"></i> LỊCH SỬ ĐƠN HÀNG</h3>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4 py-3">Mã đơn</th>
                            <th>Ngày đặt hàng</th>
                            <th class="text-end">Tổng thanh toán</th>
                            <th class="text-center pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark">#@item.OrderID</td>
                                    <td>
                                        <div class="fw-medium">@item.OrderTime.ToString("dd/MM/yyyy")</div>
                                        <div class="small text-muted">@item.OrderTime.ToString("HH:mm")</div>
                                    </td>
                                    <td class="text-end fw-bold text-danger">
                                        @{
                                            decimal totalAmount = orderTotals.ContainsKey(item.OrderID) ? orderTotals[item.OrderID] : 0;
                                        }
                                        @totalAmount.ToString("N0") đ
                                    </td>
                                    <td class="text-center pe-4">
                                        <a href="~/Order/Details/@item.OrderID" class="btn btn-sm btn-outline-primary rounded-pill px-4">
                                            Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">Chưa có đơn hàng nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>