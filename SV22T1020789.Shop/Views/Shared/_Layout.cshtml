@using Microsoft.AspNetCore.Http
@using Newtonsoft.Json
@using SV22T1020789.Shop.Models
@using SV22T1020789.Shop
@inject IHttpContextAccessor HttpContextAccessor

@{
    var context = HttpContextAccessor.HttpContext;

    // 1. Thử lấy dữ liệu giỏ hàng từ Session
    var cart = context?.Session?.Get<List<CartItem>>("ShoppingCart");

    // 2. Nếu Session trống mà khách ĐÃ đăng nhập -> Lấy từ Cookie để hiển thị luôn
    if (cart == null && User.Identity?.IsAuthenticated == true && !string.IsNullOrEmpty(User.Identity.Name))
    {
        string safeUserName = User.Identity.Name.Replace("@", "_").Replace(".", "_");
        string cookieName = $"SavedCart_{safeUserName}";

        if (context?.Request.Cookies.TryGetValue(cookieName, out string? cartJson) == true && !string.IsNullOrEmpty(cartJson))
        {
            cart = JsonConvert.DeserializeObject<List<CartItem>>(cartJson);

            // Lấy được từ Cookie rồi thì nạp ngược lại vào Session để lướt web cho nhanh
            if (cart != null)
            {
                context.Session.Set("ShoppingCart", cart);
            }
        }
    }

    // 3. Tính tổng số lượng để hiển thị trên icon
    int totalItems = cart?.Sum(x => x.Quantity) ?? 0;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - QTuan-Shop</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link href="~/css/site.css" rel="stylesheet" />

    <style>
        /* --- HIỆU ỨNG DROPDOWN MENU --- */
        .nav-item.custom-dropdown {
            position: relative;
        }

            .nav-item.custom-dropdown .dropdown-menu {
                display: block;
                opacity: 0;
                visibility: hidden;
                transform: translateY(15px);
                transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
                margin-top: 0;
                border: none;
                border-radius: 12px;
                min-width: 220px;
            }

            .nav-item.custom-dropdown:hover .dropdown-menu {
                opacity: 1;
                visibility: visible;
                transform: translateY(0);
            }

        .dropdown-item {
            transition: 0.2s ease;
            padding: 10px 20px;
            font-weight: 500;
        }

            .dropdown-item:hover {
                background-color: #f0f8ff;
                color: #0d6efd;
                transform: translateX(5px);
            }

        /* Badge giỏ hàng */
        .cart-badge {
            font-size: 0.65rem;
            top: -5px;
            right: -10px;
            padding: 0.35em 0.5em;
            min-width: 18px;
        }

        .footer-link {
            color: #adb5bd;
            text-decoration: none;
            transition: 0.3s;
            line-height: 2;
        }

            .footer-link:hover {
                color: #fff;
                padding-left: 5px;
            }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header class="sticky-top shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary fs-4" href="~/">
                    <i class="bi bi-cart-check-fill text-danger"></i> QTuan-Shop
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    @* Ô tìm kiếm *@
                    <form class="d-flex mx-auto w-50 my-2 my-lg-0" action="~/Home/Index" method="get">
                        <input class="form-control rounded-start-pill border-primary border-end-0 shadow-none"
                               type="search" name="searchValue" value="@Context.Request.Query["searchValue"]"
                               placeholder="Bạn muốn tìm gì hôm nay?..." aria-label="Search">
                        <button class="btn btn-outline-primary rounded-end-pill px-4" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>

                    <ul class="navbar-nav ms-auto align-items-center">
                        @* Giỏ hàng *@
                        <li class="nav-item me-4">
                            <a class="nav-link position-relative text-dark px-2 d-flex align-items-center" href="~/Cart">
                                <div class="position-relative">
                                    <i class="bi bi-bag fs-4"></i>
                                    <span id="cart-count" class="position-absolute badge rounded-pill bg-danger border border-white cart-badge">
                                        @totalItems
                                    </span>
                                </div>
                                <span class="d-none d-lg-inline ms-2 fw-semibold">Giỏ hàng</span>
                            </a>
                        </li>

                        @* Khu vực tài khoản *@
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown custom-dropdown z-3">
                                <a class="nav-link text-dark fw-bold d-flex align-items-center" href="#" role="button">
                                    <i class="bi bi-person-circle fs-4 text-primary me-2"></i>
                                    <span class="d-none d-lg-inline">Chào, @User.Identity.Name</span>
                                    <i class="bi bi-chevron-down ms-1 small"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow-lg mt-2">
                                    <li><a class="dropdown-item" href="~/Account/Profile"><i class="bi bi-person-vcard me-2 text-secondary"></i>Thông tin cá nhân</a></li>
                                    <li><a class="dropdown-item" href="~/Order"><i class="bi bi-clock-history me-2 text-secondary"></i>Lịch sử mua hàng</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="~/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary rounded-pill px-4 shadow-sm" href="~/Account/Login">
                                    <i class="bi bi-person-circle me-1"></i> Đăng nhập
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>

        @* Thanh danh mục sản phẩm *@
        <div class="bg-white border-bottom d-none d-md-block">
            <div class="container">
                <ul class="nav py-2 fw-medium">
                    <li class="nav-item custom-dropdown z-3">
                        <a class="nav-link text-dark px-3 fw-bold" href="~/Home/Index">
                            <i class="bi bi-grid-3x3-gap-fill text-primary me-2"></i> Danh mục sản phẩm <i class="bi bi-chevron-down ms-1 small"></i>
                        </a>
                        <ul class="dropdown-menu shadow-lg">
                            <li><a class="dropdown-item" href="~/Home/Index">Tất cả sản phẩm</a></li>
                            @if (ViewBag.Categories != null)
                            {
                                <li><hr class="dropdown-divider"></li>
                                foreach (var cat in ViewBag.Categories)
                                {
                                    <li>
                                        <a class="dropdown-item" href="~/Home/Index?categoryId=@cat.CategoryID">
                                            @cat.CategoryName
                                        </a>
                                    </li>
                                }
                            }
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </header>

    <main class="container my-4 flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-dark text-light pt-5 pb-3 mt-auto">
        <div class="container">
            <div class="row g-4 mb-4">
                <div class="col-lg-4 col-md-6">
                    <h4 class="fw-bold text-white mb-3"><i class="bi bi-cart-check-fill text-danger me-2"></i>QTuan-Shop</h4>
                    <p class="text-secondary pe-md-4">Hệ thống bán lẻ các thiết bị điện tử, đồ gia dụng và thời trang hàng đầu Việt Nam.</p>
                    <div class="d-flex gap-3 mt-3">
                        <a href="#" class="text-light fs-4"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-light fs-4"><i class="bi bi-youtube text-danger"></i></a>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h5 class="text-white mb-3 text-uppercase">Liên hệ</h5>
                    <ul class="list-unstyled text-secondary small">
                        <li class="mb-2"><i class="bi bi-geo-alt me-2 text-primary"></i> 77 Nguyễn Huệ, TP. Huế</li>
                        <li class="mb-2"><i class="bi bi-telephone me-2 text-primary"></i> Hotline: 1900 1080</li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h5 class="text-white mb-3 text-uppercase">Chính sách</h5>
                    <ul class="list-unstyled">
                        <li><a href="#" class="footer-link">Chính sách bảo mật</a></li>
                        <li><a href="#" class="footer-link">Chính sách đổi trả</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h5 class="text-white mb-3 text-uppercase">Bản tin</h5>
                    <p class="text-secondary small">Đăng ký để nhận mã giảm giá mới nhất.</p>
                    <form class="d-flex">
                        <input type="email" class="form-control rounded-start bg-secondary border-0 text-white shadow-none" placeholder="Email...">
                        <button class="btn btn-primary rounded-end" type="button"><i class="bi bi-send"></i></button>
                    </form>
                </div>
            </div>
            <div class="border-top border-secondary pt-3 text-center text-secondary small">
                &copy; @DateTime.Now.Year Bản quyền thuộc về SV22T1020789.
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>