@using Microsoft.AspNetCore.Mvc.Rendering
@{
    Layout = null;
    ViewBag.Title = "Đổi mật khẩu tài khoản";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-color: #4f46e5;
            --primary-hover: #4338ca;
            --secondary-color: #64748b;
            --bg-color: #f1f5f9;
            --input-bg: #f8fafc;
            --border-color: #e2e8f0;
        }

        body, html {
            height: 100%;
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-color);
        }

        .login-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-container {
            background: #ffffff;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            width: 100%;
            max-width: 1000px;
            display: flex;
            min-height: 600px;
        }

        .login-sidebar {
            flex: 1;
            background-image: linear-gradient(135deg, rgba(79, 70, 229, 0.85) 0%, rgba(67, 56, 202, 0.95) 100%), url('https://images.unsplash.com/photo-1614064641935-3bb7518b2c5f?q=80&w=2070&auto=format&fit=crop');
            background-position: center;
            background-size: cover;
            color: #ffffff;
            padding: 50px 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            position: relative;
        }

        .back-link {
            position: absolute;
            top: 30px;
            left: 30px;
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            font-size: 0.9rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s ease;
        }

            .back-link:hover {
                color: #ffffff;
                transform: translateX(-4px);
            }

        .login-sidebar i.logo-icon {
            font-size: 4.5rem;
            margin-bottom: 15px;
            filter: drop-shadow(0 4px 6px rgba(0,0,0,0.2));
        }

        .login-sidebar h2 {
            font-weight: 700;
            margin-bottom: 15px;
        }

        .login-form-section {
            flex: 1.2;
            padding: 60px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

            .login-form-section h3 {
                font-weight: 700;
                color: #1e293b;
                margin-bottom: 8px;
            }

        .sub-title {
            color: var(--secondary-color);
            margin-bottom: 35px;
            font-size: 0.95rem;
        }

        .form-floating > .form-control {
            border-radius: 12px;
            border: 1px solid var(--border-color);
            background-color: var(--input-bg);
            transition: all 0.2s ease;
        }

            .form-floating > .form-control:focus {
                background-color: #ffffff;
                border-color: var(--primary-color);
                box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.15);
            }

        .btn-submit {
            background-color: var(--primary-color);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 600;
            color: white;
            transition: all 0.3s ease;
        }

            .btn-submit:hover {
                background-color: var(--primary-hover);
                transform: translateY(-2px);
                box-shadow: 0 8px 20px rgba(79, 70, 229, 0.3);
            }

        @@media (max-width: 768px) {
            .login-container

        {
            flex-direction: column;
        }

        .login-sidebar {
            padding: 60px 20px 40px;
            min-height: auto;
        }

        .login-form-section {
            padding: 40px 25px;
        }

        }
    </style>
</head>
<body>

    <div class="login-wrapper">
        <div class="login-container">
            <div class="login-sidebar">
                <a href="~/Account/Profile" class="back-link">
                    <i class="bi bi-arrow-left"></i> Quay lại hồ sơ
                </a>
                <i class="bi bi-shield-lock-fill text-warning logo-icon"></i>
                <h2>Bảo mật</h2>
                <p>Thiết lập mật khẩu mới để tăng cường bảo mật cho tài khoản của bạn.</p>
            </div>

            <div class="login-form-section">
                <h3>Đổi mật khẩu</h3>
                <p class="sub-title">Vui lòng điền thông tin để cập nhật mật khẩu mới</p>

                @if (TempData["SuccessPassword"] != null)
                {
                    <div class="alert alert-success border-0 shadow-sm mb-4 small">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessPassword"]
                    </div>
                }
                @if (TempData["ErrorPassword"] != null)
                {
                    <div class="alert alert-danger border-0 shadow-sm mb-4 small">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorPassword"]
                    </div>
                }

                <form action="~/Account/ChangePassword" method="post" class="needs-validation" novalidate>

                    <div class="form-floating mb-3 has-validation">
                        <input type="password" name="oldPassword" class="form-control" id="oldPwd" required placeholder="Mật khẩu hiện tại" />
                        <label for="oldPwd"><i class="bi bi-key me-2"></i>Mật khẩu hiện tại</label>
                        <div class="invalid-feedback">
                            Vui lòng nhập mật khẩu hiện tại!
                        </div>
                    </div>

                    <div class="form-floating mb-3 has-validation">
                        <input type="password" name="newPassword" class="form-control" id="newPwd" required minlength="6" placeholder="Mật khẩu mới" />
                        <label for="newPwd"><i class="bi bi-shield-plus me-2"></i>Mật khẩu mới</label>
                        <div class="invalid-feedback">
                            Mật khẩu mới phải có ít nhất 6 ký tự!
                        </div>
                    </div>

                    <div class="form-floating mb-4 has-validation">
                        <input type="password" name="confirmPassword" class="form-control" id="confirmPwd" required minlength="6" placeholder="Xác nhận mật khẩu" />
                        <label for="confirmPwd"><i class="bi bi-check-all me-2"></i>Xác nhận mật khẩu mới</label>
                        <div class="invalid-feedback">
                            Vui lòng xác nhận lại mật khẩu (ít nhất 6 ký tự)!
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-submit">
                            Cập nhật mật khẩu <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')

            Array.prototype.slice.call(forms)
                .forEach(function (form) {
                    form.addEventListener('submit', function (event) {
                        if (!form.checkValidity()) {
                            event.preventDefault()
                            event.stopPropagation()
                        }
                        form.classList.add('was-validated')
                    }, false)
                })
        })()
    </script>
</body>
</html>